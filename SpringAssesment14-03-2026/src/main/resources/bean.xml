<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
       http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="book" class="com.cg.Book">
<!--        <property name="bookId" value="101"/>-->
<!--        <property name="title" value="Spring Framework"/>-->
<!--        <property name="author" value="Rod Johnson"/>-->
        <constructor-arg name="bookId" value="101"/>
        <constructor-arg name="title" value="Spring Framework"/>
        <constructor-arg name="author" value="Rod Johnson"/>
    </bean>

    <bean id="librarian" class="com.cg.Librarian">
<!--        <property name="librarianId" value="1"/>-->
<!--        <property name="name" value="Amit"/>-->
<!--        <property name="book" ref="book"/>-->
        <constructor-arg name="librarianId" value="1"/>
        <constructor-arg name="name" value="Amit"/>
        <constructor-arg name="book" ref="book"/>
    </bean>

</beans>